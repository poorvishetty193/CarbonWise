# ──────────────────────────────────────────────────────────────
# CarbonWise — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to source control.
# ──────────────────────────────────────────────────────────────

# ── Firebase Client SDK (public — safe to expose in browser) ──
NEXT_PUBLIC_FIREBASE_API_KEY=your_web_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Firebase Admin SDK (server-only — NEVER expose to client) ──
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Paste the private key exactly as-is from the JSON file (with literal \n)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"

# ── Session Cookie Signing (next-firebase-auth-edge) ──────────
# Must be at least 32 characters long. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET_KEY_CURRENT=replace-with-a-random-32-plus-char-secret-string-here
COOKIE_SECRET_KEY_PREVIOUS=replace-with-another-random-32-plus-char-secret-string

# ── Google Gemini AI (optional — free tier) ───────────────────
# If absent, the app uses a mock streaming response instead.
# Get from: https://aistudio.google.com/apikey (free, no billing required)
GEMINI_API_KEY=your-gemini-api-key-here

# ── Bundle Analyser (dev only) ────────────────────────────────
# Set to "true" and run: npm run build
ANALYZE=false
